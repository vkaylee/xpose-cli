# Staging Environment Configuration
# Copy this file to .env.staging and fill in real values
#
# Setup: ./dev.sh staging-setup
# This will create D1, run migrations, deploy worker, and set secrets.

# Cloudflare API Authentication
CLOUDFLARE_API_TOKEN=your-api-token-here
CLOUDFLARE_ACCOUNT_ID=your-account-id-here

# D1 Database (auto-created by staging-setup if empty)
STAGING_D1_ID=your-staging-d1-id-here

# Worker URL (update after first deploy)
STAGING_WORKER_URL=https://key-server-staging.<your-subdomain>.workers.dev

# Dynamic Tunnel Provisioning (required for CLI tunnel allocation)
# Token needs "Cloudflare Tunnel: Edit" permission
CLOUDFLARE_API_TUNNEL_TOKEN=your-tunnel-api-token-here
# Domain for tunnel subdomains, e.g. "tunnels.example.com"
CLOUDFLARE_TUNNEL_DOMAIN=your-tunnel-domain-here
